            <xs:documentation xml:lang="en">The name of the processed file.</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="Path" type="xs:string">
          <xs:annotation>
            <xs:documentation xml:lang="en">Processing folder</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="DataSets" type="CAPI_PL_DataSets">
          <xs:annotation>
            <xs:documentation xml:lang="en">Provides information on each item provided in the file.</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="ValidationMessages" type="CAPI_PL_ValidationMessages" maxOccurs="unbounded" />
        <xs:element name="Message" type="xs:string">
          <xs:annotation>
            <xs:documentation xml:lang="en">In case of a general exception. Details can be found in the system logging.</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="StatusCode" type="xs:string">
          <xs:annotation>
            <xs:documentation xml:lang="en">Gets an http status code (in case the response belongs to a Web-API processing).</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
